<script>
    function ans(el, isCorrect) {
        let opts = el.parentElement.querySelectorAll('.option');
        // Disable all options in this block after one click
        opts.forEach(o => o.style.pointerEvents = 'none');
        
        if (isCorrect) {
            el.classList.add('correct');
        } else {
            el.classList.add('wrong');
            // Show the correct answer even if user clicked wrong
            opts.forEach(o => {
                if(o.getAttribute('onclick').includes('true')) {
                    o.classList.add('correct');
                }
            });
        }
    }
</script>

